{
  "name": "argleg-mcp",
  "version": "0.1.57",
  "private": true,
  "description": "MCP server for Argentine legislation (read-only, local source of truth).",
  "type": "module",
  "bin": {
    "argleg-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "node scripts/bump-version.mjs",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "fetch": "tsx src/scripts/fetch-infoleg.ts",
    "db:init": "tsx src/scripts/db-init.ts",
    "db:import": "tsx src/scripts/db-import.ts",
    "db:reset": "tsx src/scripts/db-import.ts --reset",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
