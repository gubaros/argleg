{
  "name": "argleg-mcp",
  "version": "0.1.39",
  "private": true,
  "description": "MCP server for Argentine legislation (read-only, local source of truth).",
  "type": "module",
  "bin": {
    "argleg-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "node scripts/bump-version.mjs",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "fetch": "tsx src/scripts/fetch-infoleg.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
